# ─── Trovly env template ─────────────────────────────────────
# Copy to .env and fill in. Never commit .env.
# In Streamlit Cloud, set these as secrets in the app dashboard.

# ─── Notifications ───────────────────────────────────────────
DISCORD_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Job source APIs ─────────────────────────────────────────
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
USAJOBS_API_KEY=
USAJOBS_EMAIL=

# ─── Runtime (optional) ──────────────────────────────────────
# TROVLY_ENV: dev | staging | prod  (controls log level + feature flags)
TROVLY_ENV=dev
LOG_LEVEL=INFO
